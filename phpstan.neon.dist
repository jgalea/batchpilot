includes:
  - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
  level: 6
  paths:
    - src
    - content-ops.php
    - uninstall.php
  excludePaths:
    - vendor
    - node_modules
    - assets/build
    - tests
  bootstrapFiles:
    - vendor/autoload.php
  treatPhpDocTypesAsCertain: false
  ignoreErrors:
    # Action Scheduler is loaded at runtime (bundled in vendor/woocommerce/action-scheduler)
    # but its functions and classes aren't shipped in phpstan-wordpress stubs.
    - message: '#Function as_schedule_(single|recurring)_action not found\.#'
      path: src/Async/ActionSchedulerBridge.php
    - message: '#Class ActionScheduler_NullAction not found\.#'
      path: src/Async/ActionSchedulerBridge.php
    # WP-CLI\Utils\format_items ships with WP-CLI at runtime; not in phpstan-wordpress.
    - message: '#Function WP_CLI\\Utils\\format_items not found\.#'
      path: src/CLI/DoctorCommand.php
    # ExecutionService holds dependencies required by later features (snapshots, preview tokens).
    - message: '#Property ContentOps\\Execution\\ExecutionService::\$(snapshots_repo|token_generator|token_store) is never read, only written\.#'
      path: src/Execution/ExecutionService.php
    # ExecuteController retains TokenStore to match plan signature; verifier wraps it internally.
    - message: '#Property ContentOps\\REST\\ExecuteController::\$token_store is never read, only written\.#'
      path: src/REST/ExecuteController.php
    - message: '#Property ContentOps\\CLI\\CommandRegistrar::\$(execution|targets|operations|operations_repo) is never read, only written\.#'
      path: src/CLI/CommandRegistrar.php
    - message: '#Property ContentOps\\Abilities\\AbilitiesBridge::\$(execution|targets|operations) is never read, only written\.#'
      path: src/Abilities/AbilitiesBridge.php
