# Files and directories that should not ship to the WordPress.org package.
/.git
/.github
/.wordpress-org
/.distignore
/.secret-scan-allow

# CI leftovers — must never ship (DOCKER_ENV dumps the runner environment).
/DOCKER_ENV
/Dockerfile-php-build
/docker_tag
/output.log
/.editorconfig
/.gitignore
/.wp-env.json
/CHANGELOG.md
/README.md
/docs
/jest-unit.config.js
/node_modules
/package.json
/package-lock.json
/phpcs.xml.dist
/phpstan.neon.dist
/phpunit-integration.xml.dist
/phpunit.xml.dist
/test-results
/tests
/assets/src
